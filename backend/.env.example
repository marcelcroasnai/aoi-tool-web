# ─── AOI Tool — backend environment ───────────────────────────────────────────
# Copy to `.env` and adjust. All values fall back to the defaults in config.py
# when unset, so on the original Windows machine nothing needs to be set.

# Root of the file server (drive P:/ on Windows, CIFS mount on the RPi).
# Windows default: P:/      RPi example: /mnt/aoi
AOI_DRIVE_ROOT=/mnt/aoi

# Project root — where the SQLite DB, logs/ and Docs/ live.
# Windows default: C:/Users/<you>/Documents/aoi-web/
# RPi example:     /home/pi/aoi-web/
AOI_PROJECT_ROOT=/home/pi/aoi-web/

# Auftragsplan (production plan) URL on the company intranet.
AOI_AP_URL=http://intranet.example.local/fertigung/info/auftragsplan.cgi?iieborder=1&mode=SMD

# Internal UNC path to empty-LP / Quins projects (Windows only).
AOI_EMPTY_LP_PATH=\\SERVER\share\Projekte

# Path to the customer-names CSV (defaults to <project_root>/Docs/kunde_names.csv).
# AOI_KUNDE_CSV=/home/pi/aoi-web/Docs/kunde_names.csv

# Local test fixtures root (used in test mode).
# AOI_TEST_PATH=/home/pi/aoi-web/test
