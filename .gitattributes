# Normalize line endings — repo currently has mixed CRLF/LF
* text=auto eol=lf

# Shell scripts and systemd units must stay LF for the RPi
*.sh    text eol=lf
*.service text eol=lf

# Windows batch files stay CRLF
*.bat   text eol=crlf
*.cmd   text eol=crlf

# Binary assets — never normalize
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.xlsx  binary
*.db    binary
